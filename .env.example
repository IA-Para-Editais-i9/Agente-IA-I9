# Copie para `.env` na raiz e preencha os valores. Nunca commite o arquivo `.env`.
# Serviços citados no guia de contribuição: Groq, Gemini, Langfuse.

# Groq (API de inferência)
GROQ_API_KEY=

# Google Gemini (alternativa ou complemento à Groq)
GOOGLE_API_KEY=

# Langfuse — monitoramento de chamadas LLM (opcional)
# Cloud (recomendado): criar conta em https://cloud.langfuse.com e usar
#                       LANGFUSE_HOST=https://cloud.langfuse.com
# Self-hosted: rodar `docker compose --profile monitoring up -d` e manter
#              LANGFUSE_HOST=http://localhost:3000
# Sem chaves configuradas, o cliente cai num NoOp e nao quebra o pipeline.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ChromaDB (se usar cliente remoto; local em disco usa pasta gitignored)
# CHROMA_API_KEY=
# CHROMA_TENANT=
# CHROMA_DATABASE=
