# Copie para `.env` na raiz e preencha os valores. Nunca commite o arquivo `.env`.
# Serviços citados no guia de contribuição: Groq, Gemini, Langfuse.

# Groq (API de inferência)
GROQ_API_KEY=

# Google Gemini (alternativa ou complemento à Groq)
GOOGLE_API_KEY=

# Langfuse (observabilidade — alinhar com docker-compose se self-hosted)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ChromaDB (se usar cliente remoto; local em disco usa pasta gitignored)
# CHROMA_API_KEY=
# CHROMA_TENANT=
# CHROMA_DATABASE=
